{
  "name": "okchroma",
  "version": "0.1.0",
  "license": "MIT",
  "scripts": {
    "generate": "node dist/build-script.js",
    "demo:build": "node esbuild.config.js",
    "build": "node esbuild.config.js",
    "dev": "node esbuild.config.js --watch",
    "audit": "esbuild scripts/dark-audit.ts --bundle --platform=node --outfile=dist/dark-audit.js && node dist/dark-audit.js",
    "audit:bless": "esbuild scripts/dark-audit.ts --bundle --platform=node --outfile=dist/dark-audit.js && node dist/dark-audit.js --bless",
    "highlight-audit": "esbuild scripts/highlight-audit.ts --bundle --platform=node --outfile=dist/highlight-audit.js && node dist/highlight-audit.js",
    "highlight-audit:bless": "esbuild scripts/highlight-audit.ts --bundle --platform=node --outfile=dist/highlight-audit.js && node dist/highlight-audit.js --bless",
    "audit:divergence": "esbuild scripts/divergence-audit.ts --bundle --platform=node --outfile=dist/divergence-audit.js && node dist/divergence-audit.js",
    "audit:divergence:bless": "esbuild scripts/divergence-audit.ts --bundle --platform=node --outfile=dist/divergence-audit.js && node dist/divergence-audit.js --bless",
    "sweep": "esbuild scripts/gamut-sweep.ts --bundle --platform=node --outfile=dist/gamut-sweep.js && node dist/gamut-sweep.js",
    "sweep:collision": "esbuild scripts/collision-sweep.ts --bundle --platform=node --outfile=dist/collision-sweep.js && node dist/collision-sweep.js",
    "lab:calibration": "esbuild scripts/calibration-lab.ts --bundle --platform=node --outfile=dist/calibration-lab.js && node dist/calibration-lab.js",
    "sweep:pole": "esbuild scripts/wcag-pole-sweep.ts --bundle --platform=node --outfile=dist/wcag-pole-sweep.js && node dist/wcag-pole-sweep.js",
    "smooth": "esbuild scripts/smoothness-audit.ts --bundle --platform=node --outfile=dist/smoothness-audit.js && node dist/smoothness-audit.js",
    "smooth:baseline": "esbuild scripts/smoothness-audit.ts --bundle --platform=node --outfile=dist/smoothness-audit.js && node dist/smoothness-audit.js --baseline",
    "figma:verify": "esbuild scripts/figma-verify.ts --bundle --platform=node --outfile=dist/figma-verify.js && node dist/figma-verify.js",
    "req:audit": "esbuild scripts/reqtoken-audit.ts --bundle --platform=node --outfile=dist/reqtoken-audit.js && node dist/reqtoken-audit.js",
    "audit:secondary": "esbuild scripts/secondary-audit.ts --bundle --platform=node --outfile=dist/secondary-audit.js && node dist/secondary-audit.js",
    "plugin:build": "node esbuild.config.js --plugin",
    "plugin-ext:build": "node esbuild.config.js --plugin-ext",
    "audit:register": "esbuild scripts/register-audit.ts --bundle --platform=node --outfile=dist/register-audit.js && node dist/register-audit.js",
    "audit:ext": "esbuild scripts/ext-override-audit.ts --bundle --platform=node --outfile=dist/ext-override-audit.js && node dist/ext-override-audit.js",
    "audit:ext:bless": "esbuild scripts/ext-override-audit.ts --bundle --platform=node --outfile=dist/ext-override-audit.js && node dist/ext-override-audit.js --bless",
    "typecheck": "tsc --noEmit",
    "typecheck:ext": "tsc --noEmit -p plugin-ext"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "esbuild": "^0.28.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "lucide-react": "^1.17.0"
  }
}
